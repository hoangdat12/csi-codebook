% % Khởi tạo ma trận W1 và W2
% W1 = [
%    0.1768 + 0.0000i   0.1768 + 0.0000i   0.1768 + 0.0000i   0.1768 + 0.0000i;
%   -0.1768 + 0.0000i   0.0000 - 0.1768i  -0.1768 + 0.0000i   0.0000 - 0.1768i;
%    0.1768 + 0.0000i  -0.1768 + 0.0000i   0.1768 + 0.0000i  -0.1768 + 0.0000i;
